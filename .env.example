# Supabase — required for cloud sync (zeity_db single-row table + klary_notes journal)
VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=""

# Groq (local dev reads `groq` or GROQ_API_KEY; Netlify uses GROQ_API_KEY)
GROQ_API_KEY=""

# Gemini Live API (local dev + Netlify — server-side only, for ephemeral tokens)
# In Netlify: Site settings → Environment variables → add GEMINI_API, then redeploy.
GEMINI_API=""

# zeity_db uses anon RLS policies (single-user personal app). Keep the anon key private.
# Run supabase/migrations/001_zeity_db.sql in your Supabase SQL editor before first use.
